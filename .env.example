# ── Database (Neon) ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:[PASSWORD]@ep-xxx.neon.tech/neondb?sslmode=require"

# ── NextAuth ───────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="change-me-min-32-chars-nextauth-secret"

# ── JWT (custom auth) ─────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-min-32-chars-access-secret"
JWT_REFRESH_SECRET="change-me-min-32-chars-refresh-secret"

# ── Resend (Email OTP / Thông báo) ────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="Thuận Chuyến <no-reply@thuanduong.vn>"

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# ── Apple OAuth (Sign in with Apple) ──────────────────────────────────────────
# = Service ID (web) hoặc Bundle ID (app). Là audience để verify identityToken.
APPLE_CLIENT_ID="com.thuanchuyen.app"

# ── Facebook OAuth ────────────────────────────────────────────────────────────
# Lấy tại https://developers.facebook.com → app → Settings → Basic
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"

# ── Goong Maps ────────────────────────────────────────────────────────────────
GOONG_API_KEY="your-goong-server-api-key"
NEXT_PUBLIC_GOONG_MAPTILES_KEY="your-goong-maptiles-key"

# ── Supabase Realtime (chỉ dùng Realtime + Storage, DB = Neon) ────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[project].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── Zalo ZNS (OTP SMS & thông báo) ───────────────────────────────────────────
ZALO_OA_ID="your-oa-id"
ZALO_APP_ID="your-app-id"
ZALO_APP_SECRET="your-app-secret"
ZALO_OA_ACCESS_TOKEN="your-access-token"
ZALO_ZNS_TEMPLATE_TRIP_ACCEPTED="123456"
ZALO_ZNS_TEMPLATE_PAYMENT_SUCCESS="123457"
ZALO_ZNS_TEMPLATE_TRIP_STARTED="123458"
ZALO_ZNS_TEMPLATE_TRIP_COMPLETED="123459"
ZALO_ZNS_TEMPLATE_WALLET_CREDIT="123460"
ZALO_ZNS_TEMPLATE_KYC_RESULT="123461"
# Thông báo Zalo khi khách đặt chuyến / gửi hàng thành công
ZALO_ZNS_TEMPLATE_TRIP_BOOKED="123462"
ZALO_ZNS_TEMPLATE_CARGO_BOOKED="123463"
# (Tùy chọn) refresh token OA để tự làm mới access token ~25h — xem lưu ý bên dưới
ZALO_OA_REFRESH_TOKEN="your-oa-refresh-token"

# ── PayOS (Thanh toán) ────────────────────────────────────────────────────────
PAYOS_CLIENT_ID="your-payos-client-id"
PAYOS_API_KEY="your-payos-api-key"
PAYOS_CHECKSUM_KEY="your-payos-checksum-key"
PAYOS_RETURN_URL="https://your-domain.com/payment/payos/return"
PAYOS_CANCEL_URL="https://your-domain.com/payment/payos/cancel"

# ── Upstash Redis (Rate Limiting) ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://[id].upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ── Cron ─────────────────────────────────────────────────────────────────────
CRON_SECRET="change-me-min-32-chars-cron-secret"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-domain.com"
APP_ENV="production"
